---
import FlavorLandingPage from '../../components/FlavorLandingPage.astro';
import {
  currentReleaseVersion,
  dmgDownloadUrl,
} from '../../data/currentRelease';

const version = currentReleaseVersion('XYZConvert');
---

<FlavorLandingPage
  appName="XYZConvert"
  pageTitle="XYZConvert - PDF Conversion and Media Compression for macOS"
  metaDescription="Convert files to PDF and compress videos or GIFs directly from Finder on macOS."
  pagePath="/xyzconvert/"
  heroTitle="Convert to PDF & compress, from Finder."
  heroDescription="<strong>Convert files to PDF</strong> and <strong>compress videos or GIFs</strong> from Finder with a focused macOS utility."
  heroNote="Works from Finder Quick Actions and stays focused on conversion workflows. This flavor does not include Gmail, Drive, or the broader AI toolset."
  heroTagline="Download the conversion-focused macOS utility flavor."
  sectionIntro="XYZConvert installs two Finder actions for conversion workflows and keeps settings and history inside the app."
  downloadUrl={dmgDownloadUrl('XYZConvert')}
  version={version}
  requirements={[
    'macOS 13.0 or later',
    'Internet connection may be required for some conversion workflows',
    'Enough disk space for temporary conversion output',
  ]}
  nextSteps={[
    'We review your request and send an invite.',
    'You install the build and enable the conversion actions in Finder if needed.',
    'You can immediately convert files to PDF or compress media from Finder.',
  ]}
  useCases={[
    'Convert documents to PDF',
    'Compress videos',
    'Compress GIFs',
    'General conversion workflow',
  ]}
  whereCards={[
    {
      icon: 'folder',
      title: 'Finder (files & folders)',
      subtitle: 'Right-click in Finder → Quick Actions / Services',
      items: [
        { title: 'Convert to PDF', description: 'Turn supported files into PDFs from Finder.' },
        { title: 'Compress video & GIFs', description: 'Reduce media size for faster sharing.' },
      ],
    },
    {
      icon: 'app',
      title: 'Inside the app',
      subtitle: 'History, settings, and conversion preferences',
      items: [
        { title: 'History', description: 'Review recent conversion and compression runs.' },
        { title: 'PDF settings', description: 'Adjust conversion-related preferences from the app.' },
        { title: 'Service controls', description: 'Enable or disable the available conversion actions.' },
      ],
    },
  ]}
  features={[
    {
      icon: 'document',
      title: 'Convert to PDF',
      description: 'Create PDFs directly from Finder without opening a separate desktop utility first.',
    },
    {
      icon: 'compress',
      title: 'Compress video & GIFs',
      description: 'Shrink larger media files so they are easier to upload, email, or archive.',
    },
    {
      icon: 'chart',
      title: 'Conversion history',
      description: 'See what you converted recently and keep a record of completed jobs.',
    },
    {
      icon: 'app',
      title: 'Focused conversion app',
      description: 'Use a stripped-down macOS app dedicated to document and media conversion workflows.',
    },
  ]}
  steps={[
    { title: 'Select files', description: 'Choose a document, video, or GIF in Finder.' },
    { title: 'Pick a conversion action', description: 'Use Quick Actions to convert to PDF or compress media.' },
    { title: 'Save the result', description: 'The app processes the file and keeps the result in your normal macOS workflow.' },
  ]}
/>
