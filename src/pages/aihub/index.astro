---
import FlavorLandingPage from '../../components/FlavorLandingPage.astro';
import {
  currentReleaseVersion,
  dmgDownloadUrl,
} from '../../data/currentRelease';

const version = currentReleaseVersion('AIHub');
---

<FlavorLandingPage
  appName="AI Hub"
  pageTitle="AI Hub - Finder and Text AI Actions for macOS"
  metaDescription="Analyze files, run text AI actions, and use AI chats or squads from a focused macOS app."
  pagePath="/aihub/"
  heroDescription="Run <strong>AI file analysis</strong>, <strong>selected-text actions</strong>, <strong>AI chats</strong>, and <strong>AI squads</strong> from a focused macOS app."
  heroNote="AI Hub keeps the AI-specific capabilities from the larger QuiKey app: Finder analysis actions, selected-text tools, AI chats, and squads. It does not include Gmail, Drive, or conversion-focused workflows."
  heroTagline="Download the AI-focused macOS workflow flavor."
  sectionIntro="AI Hub installs AI actions in Finder and the macOS Services menu, and unlocks chats and squads inside the app."
  downloadUrl={dmgDownloadUrl('AIHub')}
  version={version}
  requirements={[
    'macOS 13.0 or later',
    'Internet connection',
    'A supported AI provider account, API key, or subscription depending on mode',
  ]}
  nextSteps={[
    'We review your request and send an invite.',
    'You install the build and configure your preferred AI providers.',
    'Finder, selected-text AI actions, chats, and squads become available in one focused app.',
  ]}
  useCases={[
    'Analyze files with AI',
    'Use text AI tools',
    'AI chats',
    'AI squads',
    'All AI workflows',
  ]}
  whereCards={[
    {
      icon: 'folder',
      title: 'Finder (files & folders)',
      subtitle: 'Right-click in Finder → Quick Actions / Services',
      items: [
        { title: 'Analyze with ChatGPT', description: 'Send files to ChatGPT for analysis.' },
        { title: 'Analyze with Gemini', description: 'Send files to Gemini for analysis.' },
        { title: 'Analyze with Claude', description: 'Send files to Claude for analysis.' },
      ],
    },
    {
      icon: 'text',
      title: 'Any app (selected text)',
      subtitle: 'Select text → right-click → Services',
      items: [
        { title: 'Analyze, summarize, explain', description: 'Run text AI actions without switching apps.' },
        { title: 'Translate and define', description: 'Use AI text tools on whatever text you selected.' },
        { title: 'Grammar check', description: 'Clean up text directly from the macOS Services menu.' },
      ],
      footnote: 'Supported providers include ChatGPT, Gemini, and Claude.',
    },
    {
      icon: 'app',
      title: 'Inside the app',
      subtitle: 'Chats, squads, provider settings, and history',
      items: [
        { title: 'AI Chats', description: 'Keep ongoing conversations with file context and history.' },
        { title: 'AI Squads', description: 'Run multi-step workflows across multiple providers.' },
        { title: 'Provider controls', description: 'Configure AI providers, modes, and credentials.' },
      ],
    },
  ]}
  features={[
    {
      icon: 'sparkles',
      title: 'Analyze files with AI',
      description: 'Run file analysis from Finder using ChatGPT, Gemini, or Claude.',
    },
    {
      icon: 'text',
      title: 'AI actions for selected text',
      description: 'Analyze, summarize, explain, translate, define, or grammar-check text from anywhere in macOS.',
    },
    {
      icon: 'bubble',
      title: 'AI Chats',
      description: 'Chat with AI using your files and keep local conversation history inside the app.',
    },
    {
      icon: 'users',
      title: 'AI Squads',
      description: 'Combine multiple AI providers into a single coordinated workflow.',
    },
    {
      icon: 'rocket',
      title: 'Model and provider flexibility',
      description: 'Choose the provider setup that fits your workflow, including supported API and subscription modes.',
    },
  ]}
  steps={[
    { title: 'Select a file or text', description: 'Start from Finder for file analysis or from any app for selected-text actions.' },
    { title: 'Choose an AI action', description: 'Pick the provider or workflow you want from the macOS menu or from inside the app.' },
    { title: 'Review and continue', description: 'Get the result immediately, then continue in chats, squads, or history as needed.' },
  ]}
/>
