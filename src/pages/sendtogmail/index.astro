---
import FlavorLandingPage from '../../components/FlavorLandingPage.astro';

const version = 'v2026.02.10';
---

<FlavorLandingPage
  appName="Send to Gmail/Drive"
  pageTitle="Send to Gmail/Drive - Gmail and Drive Quick Actions for macOS"
  metaDescription="Create Gmail drafts with files and upload to Google Drive directly from Finder on macOS."
  pagePath="/sendtogmail/"
  heroDescription="<strong>Create Gmail drafts with selected files</strong> and <strong>upload files to Google Drive</strong> directly from Finder on macOS."
  heroNote="Works anywhere Finder shows Quick Actions, including Desktop, Downloads, AirDrop, and normal Finder folders. This flavor is focused on Google workflows and does not include the broader QuiKey AI or conversion toolset."
  heroTagline="Join the early access list for the Gmail and Drive-focused macOS workflow."
  sectionIntro="Send to Gmail/Drive installs two Finder actions and keeps Google-focused history and settings inside the app."
  downloadUrl={`https://github.com/tomer-ben-david/2025-send-to-gmail-website/releases/download/${version}/SendToGmailDrive_${version}_arm64.dmg`}
  version={version}
  requirements={[
    'macOS 13.0 or later',
    'A Google account for Gmail and Drive actions',
    'Internet connection',
  ]}
  nextSteps={[
    'We review your request and send an invite.',
    'You install the build and sign in to your Google account.',
    'Finder Quick Actions become available for Gmail and Drive workflows.',
  ]}
  useCases={[
    'Send files to Gmail drafts',
    'Upload files to Google Drive',
    'Both Gmail and Drive',
  ]}
  whereCards={[
    {
      icon: 'folder',
      title: 'Finder (files & folders)',
      subtitle: 'Right-click in Finder → Quick Actions / Services',
      items: [
        { title: 'Send to Gmail', description: 'Create a Gmail draft with the files you selected.' },
        { title: 'Upload to Drive', description: 'Upload selected items into Google Drive.' },
      ],
    },
    {
      icon: 'app',
      title: 'Inside the app',
      subtitle: 'History, settings, and Google integration',
      items: [
        { title: 'History', description: 'Review recent Gmail and Drive actions.' },
        { title: 'Google integration', description: 'Authenticate once and manage your Google connection.' },
        { title: 'Service controls', description: 'Turn the Gmail or Drive action on and off from settings.' },
      ],
    },
  ]}
  features={[
    {
      icon: 'mail',
      title: 'Send to Gmail',
      description: 'Create Gmail drafts from Finder without manually opening Gmail and attaching files one by one.',
    },
    {
      icon: 'cloud',
      title: 'Upload to Google Drive',
      description: 'Send selected files to Drive directly from Finder as a native macOS quick action.',
    },
    {
      icon: 'chart',
      title: 'Action history',
      description: 'Review what you sent recently and keep track of your Google workflow activity.',
    },
    {
      icon: 'lock',
      title: 'Google-focused setup',
      description: 'Keep Gmail and Drive configuration in one lightweight macOS app without the extra QuiKey feature set.',
    },
  ]}
  steps={[
    { title: 'Select files', description: 'Choose one or more files in Finder.' },
    { title: 'Pick Gmail or Drive', description: 'Open Quick Actions and choose the Google workflow you want.' },
    { title: 'Finish in seconds', description: 'The app drafts the Gmail message or uploads to Drive and records the result in history.' },
  ]}
/>
